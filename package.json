{
  "name": "joke-ui",
  "version": "1.64.0",
  "description": "UI for jokes",
  "author": "David Bowland",
  "engines": {
    "node": "^24.0.0"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbowland/jokes-ui.git"
  },
  "bugs": {
    "url": "https://github.com/davidbowland/jokes-ui/issues"
  },
  "homepage": "https://github.com/davidbowland/jokes-ui#readme",
  "scripts": {
    "build": "npm run clean && next build",
    "postbuild": "node scripts/generate-dynamic-pages.js && next-sitemap",
    "clean": "rm -rf .next coverage out && npm ci --legacy-peer-deps",
    "deploy": "DEVELOPMENT=true npm run build && ./scripts/deploy.sh",
    "lint": "prettier --write . && eslint --fix .",
    "prepare": "husky",
    "start": "next dev",
    "serve": "next build && npx serve out",
    "test": "jest --colors",
    "typecheck": "tsc --noEmit",
    "update": "npx update-browserslist-db@latest && ncu --doctor --target minor --upgrade && npm audit fix --audit-level=none && npm run test && npm dedupe"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^4.6.5",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@heroui/react": "^3.0.1",
    "@tanstack/react-query": "^5.83.0",
    "aws-amplify": "^5.3.33",
    "crypto-browserify": "^3.12.1",
    "fast-json-patch": "^3.1.1",
    "framer-motion": "^11.18.2",
    "husky": "^9.1.7",
    "lucide-react": "^0.577.0",
    "next": "^15.5.14",
    "next-sitemap": "^4.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.96.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-testing-library": "^6.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^13.3.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.4",
    "ts-node": "^10.9.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix",
      "jest --colors --findRelatedTests --coverageThreshold '{}' --passWithNoTests"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  }
}
